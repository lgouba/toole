DATABASE_URL="postgresql://toole:password@localhost:5432/toole"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"
OTP_DEV_CODE="1234"

# --- SMS Provider ---
# 'dev' (defaut)  : aucun SMS reel, OTP fixe a OTP_DEV_CODE (1234). Dev local.
# 'aqilas'        : provider SMS Burkina Faso (https://www.aqilas.com/app/api)
# 'africastalking': Africa's Talking (deprecated cote prod, garde pour fallback)
SMS_PROVIDER=dev

# Aqilas (requis si SMS_PROVIDER=aqilas)
AQILAS_API_KEY=""
AQILAS_SENDER_ID="TOLLE"

# Africa's Talking (requis si SMS_PROVIDER=africastalking)
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID=""
