// Prisma schema for Tolle delivery backend
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  driver
  merchant
  admin
}

enum VehicleType {
  moto
  velo
  voiture
  tricycle
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum PackageType {
  envelope
  small
  large
}

/// Categorie du colis : info contextuelle pour le livreur (gestion specifique
/// selon le type de contenu). N'impacte PAS le prix (le prix depend de la taille).
enum PackageCategory {
  meal // Repas & Nourriture
  cake // Gateaux & Patisseries
  fresh // Produits frais & surgeles (necessite froid)
  grocery // Epicerie & Autres courses
  pharmacy // Pharmacie & produits sensibles
  cosmetics // Cosmetiques & Beaute
  gift // Cadeaux & objets fragiles
  other // Colis & Divers (defaut)
}

/// Taille du colis. C'est ce qui determine le prix de base (via AppSettings).
enum PackageSize {
  small // < 5 kg
  medium // 5-20 kg
  large // > 20 kg
}

enum DeliveryStatus {
  scheduled // programmee pour plus tard, pas encore diffusee aux livreurs
  pending
  accepted
  picking_up
  picked_up
  delivering
  delivered
  cancelled
  expired
}

enum TransactionType {
  payment
  commission // gain du livreur sur une livraison (credit)
  commission_debt // dette plateforme sur un paiement cash (debit)
  tip
  topup
  withdrawal
  withdrawal_fee // reserve pour frais de retrait eventuels
  adjustment // correction manuelle admin
}

enum PaymentMethod {
  orange_money
  moov_money
  cash
  wallet
}

enum TransactionStatus {
  pending
  completed
  failed
}

enum CancelReason {
  client_cancelled
  driver_unavailable
  driver_too_far
  package_issue
  recipient_unreachable
  no_driver_found
  other
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  phone         String    @unique
  firstName     String?
  lastName      String?
  fullName      String
  dateOfBirth   DateTime?
  email         String?
  passwordHash  String? // utilise uniquement pour les admins
  userType      UserRole
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  suspendedAt   DateTime?
  suspendReason String?
  ratingAvg     Decimal   @default(5.0) @db.Decimal(2, 1)
  ratingCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driverProfile    DriverProfile?
  sentDeliveries   Delivery[]          @relation("Sender")
  drivenDeliveries Delivery[]          @relation("Driver")
  givenRatings     Rating[]            @relation("Rater")
  receivedRatings  Rating[]            @relation("Rated")
  refreshTokens    RefreshToken[]
  transactions     Transaction[]
  pushTokens       PushToken[]
  locationLogs     DriverLocationLog[]
  sentMessages     Message[]           @relation("MessageSender")
  receivedMessages Message[]           @relation("MessageRecipient")

  @@index([phone])
  @@index([userType])
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DriverProfile {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @db.Uuid
  cnibNumber         String?
  /// Photo piece d'identite (recto) — soumise au KYC par le livreur, validee par l'admin
  cnibPhotoUrl       String?
  /// Photo piece d'identite (verso)
  cnibPhotoBackUrl   String?
  vehicleType        VehicleType
  vehiclePlate       String?
  vehiclePhotoUrl    String?
  licenseNumber      String?
  licensePhotoUrl    String?
  isOnline           Boolean            @default(false)
  currentLat         Float?
  currentLng         Float?
  lastLocationUpdate DateTime?
  walletBalance      Int                @default(0)
  totalDeliveries    Int                @default(0)
  verificationStatus VerificationStatus @default(pending)
  verificationNote   String?
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isOnline])
  @@index([currentLat, currentLng])
}

model Delivery {
  id                      String           @id @default(uuid()) @db.Uuid
  reference               String           @unique
  /// Token court pour partager le suivi public (page web sans auth).
  /// Le destinataire ouvre /track/<token> et voit l'avancement en temps reel
  /// sans installer l'app. 12 caracteres hex = ~10^14 combinaisons (non
  /// devinable brute-force).
  trackingToken           String?          @unique
  senderId                String           @db.Uuid
  driverId                String?          @db.Uuid
  packageType             PackageType
  /// Categorie selectionnee par le client (info pour le livreur). Optionnel
  /// pour les anciennes courses creees avant l'ajout de cette colonne.
  packageCategory         PackageCategory?
  /// Taille du colis : drive le prix de base via AppSettings. Optionnel pour
  /// les courses pre-migration ; le serveur fallback sur packageType si null.
  packageSize             PackageSize?
  packageDescription      String?
  packagePhotoPickupUrl   String?
  packagePhotoDeliveryUrl String?
  /// Valeur declaree par le client (FCFA). Sert d'indication pour le livreur
  /// (responsabilite / niveau de soin) et base future pour l'assurance.
  declaredValue           Int?
  /// Le client a indique que le colis est fragile : le livreur doit etre averti.
  isFragile               Boolean          @default(false)
  /// Montant additionnel applique pour le tarif de nuit (snapshot du surcharge
  /// applique au moment de la creation, pour audit). 0 ou null si pas de nuit.
  nightSurchargeApplied   Int?
  /// Code promo utilise (snapshot du code en majuscules) pour audit.
  promoCode               String?
  /// Montant de la remise appliquee (FCFA, valeur positive). Null si pas de promo.
  promoDiscount           Int?
  recipientName           String
  recipientPhone          String
  /// Contact de la personne qui detient physiquement le colis au point de
  /// recuperation. Si null, l'expediteur = le client qui a passe la commande.
  senderContactName       String?
  senderContactPhone      String?
  pickupAddress           String
  pickupDetails           String?
  pickupLat               Float
  pickupLng               Float
  deliveryAddress         String
  deliveryDetails         String?
  deliveryLat             Float
  deliveryLng             Float
  estimatedDistanceKm     Decimal?         @db.Decimal(5, 1)
  price                   Int
  driverCommission        Int?
  platformFee             Int?
  tip                     Int              @default(0)
  /// Code a 4 chiffres donne par l'expediteur au livreur pour valider la recuperation
  pickupValidationCode    String           @default("0000") @db.VarChar(4)
  /// Code a 4 chiffres donne par le destinataire au livreur pour valider la livraison
  validationCode          String           @db.VarChar(4)
  status                  DeliveryStatus   @default(pending)
  /// Mode de paiement choisi par le client a la commande. Cash par defaut.
  /// Pour OM/Moov, le client paie d'avance via USSD ; en cash, le livreur encaisse.
  paymentMethod           PaymentMethod    @default(cash)
  acceptedAt              DateTime?
  pickedUpAt              DateTime?
  deliveredAt             DateTime?
  cancelledAt             DateTime?
  cancelReason            CancelReason?
  cancelComment           String?
  cancelledBy             String?          @db.Uuid
  expiresAt               DateTime?
  /// Date/heure a laquelle la livraison doit etre diffusee aux livreurs.
  /// Si null, diffusion immediate (flow classique).
  scheduledFor            DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  sender       User                @relation("Sender", fields: [senderId], references: [id])
  driver       User?               @relation("Driver", fields: [driverId], references: [id])
  ratings      Rating[]
  transactions Transaction[]
  locationLogs DriverLocationLog[]
  messages     Message[]

  @@index([senderId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([scheduledFor])
}

/// Message de chat in-app entre le client (sender de la course) et le livreur
/// assigne, rattache a une livraison. Remplace l'echange via WhatsApp.
model Message {
  id          String    @id @default(uuid()) @db.Uuid
  deliveryId  String    @db.Uuid
  senderId    String    @db.Uuid
  recipientId String    @db.Uuid
  body        String    @db.VarChar(2000)
  /// Null tant que le destinataire n'a pas ouvert le fil / lu le message.
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  delivery  Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  recipient User     @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([deliveryId, createdAt])
  @@index([recipientId, readAt])
}

model Rating {
  id         String   @id @default(uuid()) @db.Uuid
  deliveryId String   @db.Uuid
  raterId    String   @db.Uuid
  ratedId    String   @db.Uuid
  score      Int
  comment    String?
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  rater    User     @relation("Rater", fields: [raterId], references: [id])
  rated    User     @relation("Rated", fields: [ratedId], references: [id])

  @@unique([deliveryId, raterId])
  @@index([ratedId])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

/// Code OTP envoye a un utilisateur (phone OU email) pour inscription/login.
/// `identifier` contient soit le numero E.164 (ex "226XXXXXXXX"), soit l'email
/// (lowercase). Le canal d'envoi est determine cote service par la forme.
model OtpCode {
  id         String   @id @default(uuid()) @db.Uuid
  /// Numero ou email auquel l'OTP a ete envoye. Format libre, le service
  /// applique la normalisation (phone -> digits, email -> lowercase).
  identifier String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

/// Tracabilite: journal des positions GPS des livreurs.
/// Inscrit a chaque evenement important (online, offline, accept, pickup,
/// delivered) + heartbeat toutes les ~5min tant que le livreur est online.
/// Permet a un admin de reconstituer le parcours d'un livreur en cas d'incident
/// (colis disparu, litige, etc.).
model DriverLocationLog {
  id         String   @id @default(uuid()) @db.Uuid
  driverId   String   @db.Uuid
  latitude   Float
  longitude  Float
  event      String // 'online' | 'offline' | 'heartbeat' | 'accept' | 'pickup' | 'delivered' | 'cancel'
  deliveryId String?  @db.Uuid
  createdAt  DateTime @default(now())

  driver   User      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  delivery Delivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  @@index([driverId, createdAt])
  @@index([event])
  @@index([deliveryId])
}

/// Parametres globaux de la plateforme (singleton). Une seule ligne attendue,
/// avec id='default'. Modifiable uniquement par les admins. Les valeurs sont
/// consommees a la fois par le backend (pricing) et par le mobile (theming,
/// toggles d'animation, nom affiche...).
model AppSettings {
  id String @id @default("default")

  // Branding
  appName        String @default("Toolé")
  primaryColor   String @default("#1d9e75")
  secondaryColor String @default("#d85a30")

  // Monnaie / localisation
  currency       String @default("FCFA")
  currencyLocale String @default("fr-BF")

  // Pricing (FCFA par defaut). basePriceEnvelope est conserve pour
  // compatibilite avec les anciennes courses (PackageType.envelope) mais
  // n'est plus expose dans le form client. Les nouveaux prix sont bases
  // sur PackageSize (small/medium/large).
  basePriceEnvelope     Int @default(500)
  basePriceSmall        Int @default(800) // < 5 kg
  basePriceMedium       Int @default(1500) // 5-20 kg
  basePriceLarge        Int @default(2500) // > 20 kg
  pricePerKm            Int @default(100)
  platformCommissionPct Int @default(15)

  // Toggles UX
  confettiEnabled        Boolean @default(true)
  driverSoundEnabled     Boolean @default(true)
  driverVibrationEnabled Boolean @default(true)

  // Tarif de nuit : majoration appliquee si la course est cree pendant
  // la plage horaire definie (heure locale de l'app). Le montant est
  // additionne au prix total (et integralement reverse au livreur, hors
  // commission plateforme).
  nightSurchargeEnabled   Boolean @default(false)
  /// Heure de debut de la plage de nuit (0-23). Par defaut 22h.
  nightSurchargeStartHour Int     @default(22)
  /// Heure de fin de la plage de nuit (0-23). Si < startHour, on traverse
  /// minuit (ex: start=22, end=6 -> applique entre 22h et 6h du matin).
  nightSurchargeEndHour   Int     @default(6)
  /// Montant additionnel en unite de devise (FCFA) ajoute au prix.
  nightSurchargeAmount    Int     @default(0)

  // Reserve pour la tarification meteo future (non encore applique)
  rainSurchargePct Int @default(0)

  // Reglages wallet / paiement
  /// Montant minimum pour un retrait livreur (en unite de devise)
  minWithdrawAmount    Int           @default(1000)
  /// Plafond de dette commission qu'un livreur peut avoir avant d'etre
  /// bloque (il doit alors regler sa dette avant d'accepter de nouvelles courses).
  commissionDebtLimit  Int           @default(10000)
  /// Mode de paiement par defaut propose au client lors d'une commande
  defaultPaymentMethod PaymentMethod @default(cash)

  // Reglages operationnels
  /// Duree de recherche d'un livreur (avant expiration de la demande cote client)
  deliveryExpiryMinutes        Int @default(5)
  /// Delai minimum avant que le livreur puisse annuler apres avoir accepte
  /// (eviter les abus : accepter pour bloquer les autres puis annuler)
  driverCancelCooldownSeconds  Int @default(120)
  /// Rayon en km autour du pickup pour diffuser une demande aux livreurs
  nearbyRadiusKm               Int @default(5)
  /// Fraicheur GPS requise pour considerer un livreur comme disponible
  /// (si le dernier heartbeat date de plus, on le passe offline auto)
  driverHeartbeatMaxAgeSeconds Int @default(120)
  /// Delai minimum entre maintenant et l'heure choisie pour qu'une livraison
  /// soit consideree comme "programmee" (en minutes). Sous ce seuil, la
  /// livraison est diffusee immediatement aux livreurs. Permet aux admins de
  /// l'abaisser pendant les tests (ex: 2 min) ou le remonter en prod.
  scheduledMinDelayMinutes     Int @default(10)

  /// Chainage de courses : si un livreur a une course en cours mais que son
  /// ETA jusqu'a la livraison est inferieur a cette valeur (en minutes), on
  /// lui propose deja la prochaine course en tant que "chained" (banniere
  /// non-bloquante). Permet de maximiser le taux d'utilisation des livreurs
  /// (style Uber). 0 = chainage desactive.
  chainingMaxRemainingMinutes Int @default(3)

  /// Version mobile minimum supportee. Si la version installee de l'app est
  /// INFERIEURE a celle-ci (comparaison semver), l'app affiche un ecran
  /// bloquant "Mettre a jour". Permet de killer rapidement une version
  /// mobile bugguee en production. Format : "1.0.0", "1.2.3", etc.
  minSupportedAppVersion String  @default("1.0.0")
  /// Message custom affiche sur l'ecran "Mise a jour requise" (optionnel).
  forceUpdateMessage     String?

  updatedAt DateTime @updatedAt
  updatedBy String?  @db.Uuid
}

// ============================================================
// PROMO CODES (Bundle 3)
// ============================================================

enum PromoDiscountType {
  percentage // ex: 10% de reduction
  fixed // ex: -500 FCFA
}

/// Code promo cree par l'admin et utilisable par les clients lors de la
/// creation d'une livraison. La remise s'applique sur le prix client final
/// (apres tarif de nuit). La commission plateforme est calculee sur le prix
/// effectivement encaisse (le livreur ne perd pas de commission).
model PromoCode {
  id             String            @id @default(uuid()) @db.Uuid
  /// Code saisi par l'utilisateur (case-insensitive cote API, stocke en majuscules).
  code           String            @unique
  /// Type de remise : pourcentage ou montant fixe.
  discountType   PromoDiscountType
  /// Si discountType=percentage : entier 1-100. Si fixed : montant en FCFA.
  discountValue  Int
  /// Montant minimum de commande pour appliquer ce code (FCFA). Null = pas de min.
  minOrderAmount Int?
  /// Nombre total d'utilisations autorisees. Null = illimite.
  maxUses        Int?
  /// Nombre d'utilisations deja consommees (incremente atomiquement).
  currentUses    Int               @default(0)
  /// Nombre max d'utilisations par utilisateur unique. Null = illimite.
  maxUsesPerUser Int?
  /// Date de debut de validite (peut etre dans le futur pour un code planifie).
  validFrom      DateTime          @default(now())
  /// Date d'expiration. Null = pas de date limite.
  validTo        DateTime?
  /// Toggle on/off : si false, le code est refuse meme s'il est dans sa periode.
  isActive       Boolean           @default(true)
  /// Description interne (pour l'admin, non affichee au client).
  description    String?
  createdBy      String?           @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  usages PromoCodeUsage[]

  @@index([code])
  @@index([isActive])
}

/// Une utilisation d'un code promo par un user sur une livraison donnee.
/// Permet d'auditer + de comptabiliser per-user.
model PromoCodeUsage {
  id             String    @id @default(uuid()) @db.Uuid
  promoCodeId    String    @db.Uuid
  promoCode      PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId         String    @db.Uuid
  deliveryId     String    @db.Uuid
  /// Montant de la remise effectivement appliquee (FCFA).
  discountAmount Int
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([promoCodeId])
  @@index([deliveryId])
}

/// Historique des campagnes de notifications push envoyees par l'admin.
/// Permet de retrouver ce qui a ete envoye, a qui, et le taux de livraison.
model PushCampaign {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  body        String
  /// Cible : 'all' | 'clients' | 'drivers'
  target      String
  /// Nombre de tokens push successfully envoyes
  sentCount   Int      @default(0)
  /// Nombre de tokens invalides / supprimes apres l'envoi
  failedCount Int      @default(0)
  /// Admin qui a declenche la campagne (pour audit)
  createdBy   String?  @db.Uuid
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  deliveryId       String?           @db.Uuid
  type             TransactionType
  /// Montant. Positif = credit pour le userId, negatif = debit.
  amount           Int
  paymentMethod    PaymentMethod
  paymentReference String?
  /// Numero Mobile Money destinataire (pour un retrait) ou emetteur (pour un topup).
  /// Stocke au format brut "226XXXXXXXX" ; formatage XX XX XX XX cote UI.
  phoneNumber      String?
  /// Note facultative ajoutee par l'admin (ex: "vire via Orange Money", reference)
  note             String?
  /// Admin qui a valide / rejete la transaction
  processedBy      String?           @db.Uuid
  processedAt      DateTime?
  status           TransactionStatus @default(pending)
  createdAt        DateTime          @default(now())

  user     User      @relation(fields: [userId], references: [id])
  delivery Delivery? @relation(fields: [deliveryId], references: [id])

  @@index([userId])
  @@index([deliveryId])
  @@index([status])
  @@index([type])
}
