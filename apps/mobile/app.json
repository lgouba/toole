{
  "expo": {
    "name": "Toolé",
    "slug": "tolle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tolle",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#15803D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.qalitylabs.tolle",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Toolé utilise votre position pour trouver les livreurs proches et suivre les livraisons.",
        "NSCameraUsageDescription": "Toolé utilise l'appareil photo pour prendre des photos des colis (preuve de recuperation et de livraison).",
        "NSPhotoLibraryUsageDescription": "Toolé accède à votre galerie pour ajouter des photos de profil et de colis.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      }
    },
    "android": {
      "package": "com.qalitylabs.tolle",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Toolé utilise votre position pour trouver les livreurs proches et suivre les livraisons."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Toolé utilise l'appareil photo pour photographier les colis (preuve de livraison).",
          "photosPermission": "Toolé accède à vos photos pour les colis et votre avatar."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1D9E75"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7242556c-4909-4c91-8836-c2ed27619394"
      },
      "router": {}
    },
    "owner": "lgouba",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7242556c-4909-4c91-8836-c2ed27619394"
    }
  }
}
